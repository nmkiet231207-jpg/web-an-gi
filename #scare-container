<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chọn Đồ Ăn Cho 303</title>

    <meta property="og:title" content="Chọn Đồ Ăn Cho 303">
    <meta property="og:description" content="Không biết ăn gì? Nhấn vào đây để vũ trụ trả lời!">
    <meta property="og:image" content="vc.jpg">

    <style>
        body { font-family: Arial, sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; margin: 0; background-color: #f0f8ff; transition: background-color 0.3s; text-align: center; overflow: hidden; }
        #food-display { font-size: 2.5rem; font-weight: bold; margin: 20px; color: #333; min-height: 50px; }
        button { padding: 15px 30px; font-size: 1.2rem; cursor: pointer; background-color: #4CAF50; color: white; border: none; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.2); transition: 0.2s; position: relative; z-index: 1; }
        button:hover { background-color: #45a049; }
        
        /* Đã BẬT công tắc nhấp nháy 7 màu (flashBg) cho container */
        #scare-container { display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 999; justify-content: center; align-items: center; flex-direction: column; animation: flashBg 1s infinite; }
        
        /* Đã XÓA lệnh cắt ảnh, ảnh sẽ tự động co giãn ôm khít viền và RUNG LẮC */
        #scare-image { 
            max-width: 90vw; 
            max-height: 75vh; 
            width: auto; 
            height: auto; 
            border: 8px solid yellow; 
            animation: shake 0.1s infinite; 
        }
        
        #scare-text { color: yellow; font-size: 4rem; text-transform: uppercase; font-weight: bold; margin-top: 20px; text-shadow: 2px 2px 4px red; }
        body.angry h1, body.angry #food-display, body.angry button { display: none !important; }
        body.angry #scare-container { display: flex; }
        
        /* Công thức nền 7 màu */
        @keyframes flashBg {
            0% { background-color: red; }
            14% { background-color: orange; }
            28% { background-color: yellow; }
            42% { background-color: green; }
            57% { background-color: blue; }
            71% { background-color: indigo; }
            85% { background-color: violet; }
            100% { background-color: red; }
        }

        /* Đã BỔ SUNG công thức rung lắc (thủ phạm khiến ảnh đứng im lúc nãy) */
        @keyframes shake {
            0% { transform: translate(2px, 1px) rotate(0deg); }
            10% { transform: translate(-2px, -3px) rotate(-2deg); }
            20% { transform: translate(-4px, 0px) rotate(2deg); }
            30% { transform: translate(4px, 3px) rotate(0deg); }
            40% { transform: translate(2px, -2px) rotate(2deg); }
            50% { transform: translate(-2px, 3px) rotate(-2deg); }
            60% { transform: translate(-4px, 2px) rotate(0deg); }
            70% { transform: translate(4px, 2px) rotate(-2deg); }
            80% { transform: translate(-2px, -2px) rotate(2deg); }
            90% { transform: translate(2px, 3px) rotate(0deg); }
            100% { transform: translate(2px, -3px) rotate(-2deg); }
        }
    </style>
</head>
<body>

    <h1>Chuyên Gia Dinh Dưỡng Giải Quyết Minh Kiệt</h1>
    <div id="food-display">Nhấn nút bên dưới để nhận thông điệp vũ trụ!</div>
    <button id="random-btn">Hôm nay ăn gì?</button>

    <div id="scare-container">
        <img id="scare-image" src="vc.jpg" alt="JUMPSCARE">
        <div id="scare-text">HẾT LƯỢT ĐỔI RỒI!</div>
    </div>

    <script>
        const menu = [
            "Cơm rang dưa bò", "Phở bò", "Bún bò", "Cơm gà", "Bún trộn", 
            "Mỳ cay", "Nem nướng", "Bánh giò + Tào phớ", "Bún đậu mắm tôm", 
            "Cơm MaiLuot", "Bánh mỳ", "Bún chả", "Bánh cuốn"
        ];

        let clickCount = 0; 
        let lastIndex = -1; 
        const foodDisplay = document.getElementById('food-display');
        const button = document.getElementById('random-btn');

        button.addEventListener('click', function() {
            clickCount++;

            if (clickCount <= 3) {
                let randomIndex = Math.floor(Math.random() * menu.length);
                while (randomIndex === lastIndex) {
                    randomIndex = Math.floor(Math.random() * menu.length);
                }
                lastIndex = randomIndex;
                foodDisplay.innerText = menu[randomIndex];
                
                if (clickCount === 1) {
                    button.innerText = "Không thích? Đổi món khác";
                } else if (clickCount === 2) {
                    button.innerText = "Hơi kén cá chọn canh rồi đấy, bấm phát nữa xem?";
                    button.style.backgroundColor = "#ff9800";
                } else if (clickCount === 3) {
                    button.innerText = "Cảnh báo chót";
                    button.style.backgroundColor = "darkred";
                }
            } else {
                document.body.classList.add('angry');
            }
        });
    </script>
</body>
</html>
